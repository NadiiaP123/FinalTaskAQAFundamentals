{
  "BaseUrl": "https://www.saucedemo.com/",

  "Timeouts": {
    "ImplicitWait": 2,
    "ExplicitWait": 10,
    "PageLoad": 30
  },

  "Run": {
    "Parallel": false,
    "Threads": 4
  },

  "Browsers": {
    "Chrome": {
      "Enabled": true,
      "Instances": 1,
      "Headless": false
    },
    "Edge": {
      "Enabled": true,
      "Instances": 1,
      "Headless": false
    },
    "Firefox": {
      "Enabled": true,
      "Instances": 1,
      "Headless": false
    }
  }
}